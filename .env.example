# JWT signing secret for session tokens — generate with: python -c "import secrets; print(secrets.token_hex(32))"
HUB_SECRET=change-me-generate-a-strong-random-secret

# Fernet encryption key for stored API keys — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HUB_ENCRYPTION_KEY=

# SQLite database path (default: /data/hub.db for Fly.io volume mount)
DATABASE_URL=sqlite+aiosqlite:////data/hub.db

# Public base URL of this service (used in verification links)
BASE_URL=https://voice-agent-hub.fly.dev

# Google OAuth credentials — from console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of registered agent names (for dispatch logic)
LIVEKIT_AGENTS=voice-agent

# CORS origins — use "*" for development, restrict in production
CORS_ORIGINS=*
